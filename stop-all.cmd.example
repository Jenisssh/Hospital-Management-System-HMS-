@echo off
REM ============================================================================
REM  HMS v2 — Stop everything
REM
REM  Setup:
REM    1. Copy this file: copy stop-all.cmd.example stop-all.cmd
REM    2. Run stop-all.cmd to kill any process listening on HMS v2's ports.
REM ============================================================================

setlocal enabledelayedexpansion

set PORTS=5173 5174 8080 8081 8082 8083 8084 8085 8761 8888

echo Stopping HMS v2 services...
for %%P in (%PORTS%) do (
    for /f "tokens=5" %%A in ('netstat -ano ^| findstr ":%%P " ^| findstr LISTENING') do (
        echo   killing PID %%A on port %%P
        taskkill /F /PID %%A > nul 2>&1
    )
)

echo Done.
endlocal
